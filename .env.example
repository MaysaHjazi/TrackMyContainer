# ── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://trackmycontainer.ai"
NEXTAUTH_URL="https://trackmycontainer.ai"
NEXTAUTH_SECRET=""   # openssl rand -base64 32

# ── Database (Supabase) ───────────────────────────────────────
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres"
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres"

# ── Redis (Upstash) ───────────────────────────────────────────
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
# Standard Redis URL for BullMQ worker process (Railway/Render)
REDIS_URL="rediss://:[PASSWORD]@[HOST]:[PORT]"

# ── Auth: Google OAuth ────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── Stripe ────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRO_PRICE_ID="price_..."
STRIPE_BUSINESS_PRICE_ID="price_..."

# ── Tracking APIs ─────────────────────────────────────────────
# Shipsgo – https://shipsgo.com (sea freight, 160+ carriers)
SHIPSGO_API_KEY=""
SHIPSGO_BASE_URL="https://shipsgo.com/api/v2.0"

# Maersk Developer Portal – https://developer.maersk.com (free)
MAERSK_CLIENT_ID=""
MAERSK_CLIENT_SECRET=""
MAERSK_BASE_URL="https://api.maersk.com"

# TimeToCargo – sea freight fallback (free)
TIMETOCARGO_API_KEY=""
TIMETOCARGO_BASE_URL="https://api.timetocargo.com"

# AirRates – https://www.airrates.com (air freight AWB tracking)
AIRRATES_API_KEY=""
AIRRATES_BASE_URL="https://api.airrates.com"

# CHAMP Cargospot – air freight fallback
CHAMP_API_KEY=""
CHAMP_BASE_URL="https://api.developer.champ.aero"

# TrackCargo – free air freight fallback
TRACKCARGO_API_KEY=""
TRACKCARGO_BASE_URL="https://api.trackcargo.co"

# ── Twilio (WhatsApp Business) ────────────────────────────────
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_WHATSAPP_NUMBER="whatsapp:+1..."  # E.164 format prefixed with whatsapp:

# ── Meta / Facebook (Messenger Bot) ──────────────────────────
META_APP_ID=""
META_APP_SECRET=""
META_PAGE_ACCESS_TOKEN=""
META_VERIFY_TOKEN=""    # Any random string for webhook verification

# ── Email (Resend) ────────────────────────────────────────────
RESEND_API_KEY=""
RESEND_FROM_EMAIL="noreply@trackmycontainer.ai"

# ── Monitoring ────────────────────────────────────────────────
SENTRY_DSN=""
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"
